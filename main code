ESPTab:CreateSection("Player ESP")

local playerESPEnabled = false
local playerHighlights = {}

local function applyPlayerHighlight(targetPlayer)
    if targetPlayer == player then return end
    local char = targetPlayer.Character
    if not char then return end
    if playerHighlights[targetPlayer] then
        playerHighlights[targetPlayer].Adornee = char
        return
    end
    local h = Instance.new("Highlight")
    h.FillColor           = Color3.fromRGB(255, 50,  50)
    h.OutlineColor        = Color3.fromRGB(255, 255, 255)
    h.FillTransparency    = 0.5
    h.OutlineTransparency = 0
    h.Adornee             = char
    h.Parent              = player.PlayerGui
    playerHighlights[targetPlayer] = h
end

local function removePlayerHighlight(targetPlayer)
    if playerHighlights[targetPlayer] then
        playerHighlights[targetPlayer]:Destroy()
        playerHighlights[targetPlayer] = nil
    end
end

-- Connect for existing and future players
for _, p in ipairs(Players:GetPlayers()) do
