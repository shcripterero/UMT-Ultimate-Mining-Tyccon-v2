local function getOreId(part)
    -- Tries multiple attribute names in case the game uses a different one
    return part:GetAttribute("MineId")
        or part:GetAttribute("OreType")
        or part:GetAttribute("Type")
        or part:GetAttribute("BlockType")
        or part.Name
end

local function createESP(part)
    if espParts[part] or not part:IsA("BasePart") then return end
    local mineId = getOreId(part)
    local color  = oreColors[mineId] or Color3.fromRGB(255, 255, 255)

    local box = Instance.new("BoxHandleAdornment")
    box.Adornee      = part
    box.Parent       = espFolder
    box.AlwaysOnTop  = true
    box.ZIndex       = 1
    box.Size         = part.Size + Vector3.new(0.1, 0.1, 0.1)
    box.Transparency = 0.55
    box.Color3       = color
    box.Visible      = false

    local billboard = Instance.new("BillboardGui")
    billboard.Adornee     = part
    billboard.Parent      = espFolder
    billboard.Size        = UDim2.new(0, 120, 0, 22)
    billboard.StudsOffset = Vector3.new(0, part.Size.Y / 2 + 1.2, 0)
    billboard.AlwaysOnTop = true
    billboard.Enabled     = false

    local label = Instance.new("TextLabel")
    label.Parent                 = billboard
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text                   = mineId
    label.TextColor3             = color
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3       = Color3.fromRGB(0, 0, 0)
    label.TextScaled             = true
    label.Font                   = Enum.Font.GothamBold

    espParts[part] = { box = box, billboard = billboard }
end

local function removeESP(part)
    if not espParts[part] then return end
    pcall(function() espParts[part].box:Destroy() end)
    pcall(function() espParts[part].billboard:Destroy() end)
    espParts[part] = nil
end

local function getSpawnedBlocksFolder()
    return workspace:FindFirstChild("SpawnedBlocks")
        or workspace:FindFirstChild("Blocks")
        or workspace:FindFirstChild("Ores")
end

local function setupBlocks()
    local sb = getSpawnedBlocksFolder()
    if not sb then return end
    for _, child in ipairs(sb:GetChildren()) do
        if child:IsA("BasePart") then
            createESP(child)
        end
    end
end

-- Connect events once the blocks folder is available
task.spawn(function()
