-- ===================== CUSTOM TELEPORTS =====================
TeleportTab:CreateSection("Custom Teleports")

local savedTeleports  = {}
local tpCounter       = 0
local selectedTPIndex = 1

local function getTPListString()
    if #savedTeleports == 0 then return "No teleports saved.\nUse 'Save Place' to add one." end
    local lines = {}
    for i, tp in ipairs(savedTeleports) do
        local marker = (i == selectedTPIndex) and "[SEL] " or "      "
        local pos = tp.cframe.Position
        table.insert(lines, string.format("%s%d: %s  (%.0f, %.0f, %.0f)", marker, i, tp.name, pos.X, pos.Y, pos.Z))
    end
    return table.concat(lines, "\n")
end

local tpListParagraph = TeleportTab:CreateParagraph({
    Title   = "Saved Teleports  (press Refresh to update)",
    Content = "No teleports saved.",
})

local function refreshTPDisplay()
    pcall(function()
        tpListParagraph:Set({
            Title   = "Saved Teleports  (press Refresh to update)",
            Content = getTPListString(),
        })
    end)
end

TeleportTab:CreateButton({
    Name = "Save Place",
    Callback = function()
        local hrp = getHRP()
        if not hrp then return notify("Custom TP", "Character not found!", 3) end
        tpCounter = tpCounter + 1
        local newName = "TP " .. tpCounter
        table.insert(savedTeleports, { name = newName, cframe = hrp.CFrame })
        selectedTPIndex = #savedTeleports
        refreshTPDisplay()
        notify("Custom TP", "Saved as '" .. newName .. "'  (index " .. selectedTPIndex .. ")", 3)
    end,
})

TeleportTab:CreateButton({
    Name = "Refresh List",
    Callback = refreshTPDisplay,
})

TeleportTab:CreateInput({
    Name = "Select TP (by number)",
    PlaceholderText = "Enter index: 1, 2, 3...",
    NumbersOnly = true,
    Flag = "TPSelectIndex",
    Callback = function(val)
        local idx = tonumber(val)
        if idx and savedTeleports[idx] then
            selectedTPIndex = idx
            refreshTPDisplay()
            notify("Custom TP", "Selected: " .. savedTeleports[idx].name, 2)
        else
            notify("Custom TP", "Invalid index! You have " .. #savedTeleports .. " TPs saved.", 3)
        end
    end,
})

TeleportTab:CreateButton({
    Name = "Teleport to Selected",
    Callback = function()
        if #savedTeleports == 0 then return notify("Custom TP", "No teleports saved!", 3) end
        local tp = savedTeleports[selectedTPIndex]
        if not tp then return notify("Custom TP", "Invalid selection!", 3) end
        local hrp = getHRP()
        if hrp then
            hrp.CFrame = tp.cframe
            notify("Custom TP", "Teleported to " .. tp.name, 3)
        end
    end,
})

TeleportTab:CreateInput({
    Name = "Rename Selected",
    PlaceholderText = "Type new name, press Enter...",
    NumbersOnly = false,
    Flag = "TPRenameInput",
    Callback = function(val)
        if val == "" then return end
        local tp = savedTeleports[selectedTPIndex]
        if not tp then return notify("Custom TP", "No teleport selected!", 3) end
        local old = tp.name
        tp.name = val
        refreshTPDisplay()
        notify("Custom TP", "Renamed '" .. old .. "' → '" .. val .. "'", 3)
    end,
})

TeleportTab:CreateButton({
    Name = "Delete Selected",
    Callback = function()
        if #savedTeleports == 0 then return notify("Custom TP", "No teleports to delete!", 3) end
        local tp = savedTeleports[selectedTPIndex]
        if not tp then return end
        local name = tp.name
        table.remove(savedTeleports, selectedTPIndex)
        selectedTPIndex = math.max(1, math.min(selectedTPIndex, #savedTeleports))
        refreshTPDisplay()
        notify("Custom TP", "Deleted '" .. name .. "'", 3)
    end,
})

TeleportTab:CreateButton({
    Name = "Duplicate Selected",
    Callback = function()
        if #savedTeleports == 0 then return notify("Custom TP", "Nothing to duplicate!", 3) end
        local tp = savedTeleports[selectedTPIndex]
        if not tp then return end
        tpCounter = tpCounter + 1
        table.insert(savedTeleports, selectedTPIndex + 1, { name = tp.name .. " Copy", cframe = tp.cframe })
        selectedTPIndex = selectedTPIndex + 1
        refreshTPDisplay()
        notify("Custom TP", "Duplicated as '" .. tp.name .. " Copy'", 3)
    end,
})

TeleportTab:CreateButton({
    Name = "Move Up in List",
    Callback = function()
        if selectedTPIndex <= 1 then return notify("Custom TP", "Already at top!", 2) end
        local a, b = savedTeleports[selectedTPIndex], savedTeleports[selectedTPIndex - 1]
        savedTeleports[selectedTPIndex] = b
        savedTeleports[selectedTPIndex - 1] = a
        selectedTPIndex = selectedTPIndex - 1
        refreshTPDisplay()
        notify("Custom TP", "Moved '" .. savedTeleports[selectedTPIndex].name .. "' up", 2)
    end,
})

TeleportTab:CreateButton({
    Name = "Move Down in List",
    Callback = function()
        if selectedTPIndex >= #savedTeleports then return notify("Custom TP", "Already at bottom!", 2) end
        local a, b = savedTeleports[selectedTPIndex], savedTeleports[selectedTPIndex + 1]
        savedTeleports[selectedTPIndex] = b
        savedTeleports[selectedTPIndex + 1] = a
        selectedTPIndex = selectedTPIndex + 1
        refreshTPDisplay()
        notify("Custom TP", "Moved '" .. savedTeleports[selectedTPIndex].name .. "' down", 2)
    end,
})

