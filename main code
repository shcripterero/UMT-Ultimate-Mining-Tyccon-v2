local autoSellEnabled  = false
local autoSellInterval = 60
local autoSellTimer    = 0

-- Fixed: counts per second so toggling on doesn't require waiting a full interval
task.spawn(function()
    while true do
        task.wait(1)
        if not autoSellEnabled then
            autoSellTimer = 0
            continue
        end
        autoSellTimer = autoSellTimer + 1
        if autoSellTimer < autoSellInterval then continue end
        autoSellTimer = 0
        if doSellOres() then notify("Auto Sell", "Ores auto-sold!", 2) end
    end
end)

