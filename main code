-- Sell Ores
TeleportTab:CreateButton({
    Name = "Sell Ores",
    Callback = function()
        local placeablesFolder = workspace:FindFirstChild("Placeables")
        if not placeablesFolder then
            return notify("Error", "Placeables folder not found!", 4)
        end

        local function findOwnedUnloader()
            for _, folder in ipairs(placeablesFolder:GetChildren()) do
                if folder:IsA("Folder") then
                    local us = folder:FindFirstChild("UnloaderSystem")
                    if us and us:IsA("Model") and us:GetAttribute("OwnerId") == player.UserId then
                        return us
                    end
                end
            end
        end

        local hrp = getHRP()
        if not hrp then return end
        local savedPos = hrp.Position

        local unloaderSystem = findOwnedUnloader()
        if not unloaderSystem then
            return notify("Error", "No owned UnloaderSystem found!", 4)
        end

        local unloader    = unloaderSystem:FindFirstChild("Unloader")
        local cargoVolume = unloader and unloader:FindFirstChild("CargoVolume")
        local cargoPrompt = cargoVolume and cargoVolume:FindFirstChild("CargoPrompt")

        if cargoPrompt and cargoPrompt:IsA("ProximityPrompt") then
            hrp.CFrame = cargoVolume.CFrame * CFrame.new(0, 3, 0)
            task.wait(0.3)
            fireproximityprompt(cargoPrompt)
            task.wait(0.3)
            hrp.CFrame = CFrame.new(savedPos)
            notify("Sell Ores", "Ores sold successfully!", 3)
        else
            notify("Error", "CargoPrompt not found!", 4)
        end
    end,
})

