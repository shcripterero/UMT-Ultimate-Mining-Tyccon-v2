-- ===================== CAR ESP =====================
ESPTab:CreateSection("Car ESP")

local carESPEnabled = false
local carHighlights = {}

local function setupCarESP()
    local found = {}
    local seen  = {}
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("VehicleSeat") or desc:IsA("Seat") then
            local model = desc:FindFirstAncestorOfClass("Model")
            if model and not seen[model] then
                seen[model] = true
                table.insert(found, model)
            end
        end
    end
    for _, car in ipairs(found) do
        if not carHighlights[car] then
            local h = Instance.new("Highlight")
            h.FillColor           = Color3.fromRGB(50,  150, 255)
            h.OutlineColor        = Color3.fromRGB(0,   200, 255)
            h.FillTransparency    = 0.4
            h.OutlineTransparency = 0
            h.Adornee             = car
            h.Parent              = player.PlayerGui
            carHighlights[car]    = h
        end
    end
    notify("ESP", "Car ESP enabled (" .. #found .. " vehicle(s) found)", 3)
end

local function teardownCarESP()
    for _, h in pairs(carHighlights) do h:Destroy() end
    carHighlights = {}
    notify("ESP", "Car ESP disabled", 3)
end

ESPTab:CreateToggle({
    Name = "Car ESP",
    CurrentValue = false,
    Flag = "CarESP",
    Callback = function(val)
        carESPEnabled = val
        if val then setupCarESP() else teardownCarESP() end
    end,
})

