    if not spawnedBlocks then
        spawnedBlocks = workspace:WaitForChild("Blocks", 10)
    end
    if not spawnedBlocks then return end

    spawnedBlocks.ChildAdded:Connect(function(child)
        task.wait(0.1)
        if child:IsA("BasePart") then createESP(child) end
    end)

    spawnedBlocks.ChildRemoved:Connect(function(child)
        removeESP(child)
    end)

    setupBlocks()
end)

RunService.RenderStepped:Connect(function()
    local hrp = getHRP()
    if not hrp then return end
    for part, esp in pairs(espParts) do
        if part and part.Parent then
            if espEnabled then
                local visible = (hrp.Position - part.Position).Magnitude <= maxDistance
                esp.box.Visible       = visible
                esp.billboard.Enabled = visible
            else
                esp.box.Visible       = false
                esp.billboard.Enabled = false
            end
        else
            removeESP(part)
        end
    end
end)

