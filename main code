    ["Ruby"]        = Color3.fromRGB(139, 0,   0),
    ["Diamond"]     = Color3.fromRGB(43,  110, 108),
    ["Poudretteite"]= Color3.fromRGB(126, 21,  129),
    ["Zultanite"]   = Color3.fromRGB(97,  62,  48),
    ["Grandidierite"]= Color3.fromRGB(19, 109, 47),
    ["Musgravite"]  = Color3.fromRGB(24,  31,  26),
    ["Painite"]     = Color3.fromRGB(85,  21,  26),
}

local function createESP(part)
    if espParts[part] then return end
    local mineId = part:GetAttribute("MineId") or "Unknown"
    local color  = oreColors[mineId] or Color3.fromRGB(255, 255, 255)

    local box = Instance.new("BoxHandleAdornment")
    box.Adornee     = part
    box.Parent      = espFolder
    box.AlwaysOnTop = true
    box.ZIndex      = 1
    box.Size        = part.Size + Vector3.new(0.1, 0.1, 0.1)
    box.Transparency = 0.55
    box.Color3      = color
    box.Visible     = false

    local billboard = Instance.new("BillboardGui")
    billboard.Adornee     = part
    billboard.Parent      = espFolder
    billboard.Size        = UDim2.new(0, 120, 0, 22)
    billboard.StudsOffset = Vector3.new(0, part.Size.Y / 2 + 1.2, 0)
    billboard.AlwaysOnTop = true
    billboard.Enabled     = false

    local label = Instance.new("TextLabel")
    label.Parent               = billboard
    label.Size                 = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text                 = mineId
    label.TextColor3           = color
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3     = Color3.fromRGB(0, 0, 0)
    label.TextScaled           = true
    label.Font                 = Enum.Font.GothamBold

    espParts[part] = { box = box, billboard = billboard }
end

local function removeESP(part)
    if espParts[part] then
        espParts[part].box:Destroy()
        espParts[part].billboard:Destroy()
        espParts[part] = nil
    end
end

local function setupBlocks()
    local sb = workspace:FindFirstChild("SpawnedBlocks")
    if not sb then return end
    for _, block in ipairs(sb:GetChildren()) do
        if block:IsA("BasePart") then createESP(block) end
    end
end

local spawnedBlocks = workspace:WaitForChild("SpawnedBlocks")

spawnedBlocks.ChildAdded:Connect(function(child)
    if child:IsA("BasePart") then
        task.wait(0.1)
        createESP(child)
    end
end)

spawnedBlocks.ChildRemoved:Connect(function(child)
    removeESP(child)
end)

RunService.RenderStepped:Connect(function()
    local hrp = getHRP()
    if not hrp then return end
    for part, esp in pairs(espParts) do
        if part and part.Parent then
            if espEnabled then
                local visible = (hrp.Position - part.Position).Magnitude <= maxDistance
                esp.box.Visible      = visible
                esp.billboard.Enabled = visible
            else
                esp.box.Visible      = false
                esp.billboard.Enabled = false
            end
        else
            removeESP(part)
        end
    end
end)

player.CharacterAdded:Connect(function()
    for part in pairs(espParts) do removeESP(part) end
    task.wait(1)
    setupBlocks()
end)

ESPTab:CreateToggle({
    Name = "Blocks ESP",
    CurrentValue = false,
    Flag = "BlocksESP",
    Callback = function(val)
        espEnabled = val
        if val then
            setupBlocks()
            notify("ESP", "Ore ESP enabled", 3)
        else
            for _, esp in pairs(espParts) do
                esp.box.Visible       = false
                esp.billboard.Enabled = false
            end
            notify("ESP", "Ore ESP disabled", 3)
        end
    end,
})

