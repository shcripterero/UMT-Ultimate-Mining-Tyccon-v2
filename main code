-- Goto Tycoon
TeleportTab:CreateButton({
    Name = "Goto Tycoon",
    Callback = function()
        local plotsFolder = workspace:FindFirstChild("Plots")
        if not plotsFolder then
            return notify("Error", "Plots folder not found!", 4)
        end

        local function findMyPlot()
            -- Try OwnerId attribute first (newer UMT versions)
            for _, plotModel in ipairs(plotsFolder:GetChildren()) do
                if plotModel:IsA("Model") then
                    if plotModel:GetAttribute("OwnerId") == player.UserId then
                        return plotModel
                    end
                end
            end
            -- Fallback: BuildPlot has children (older logic)
            for _, plotModel in ipairs(plotsFolder:GetChildren()) do
                if plotModel:IsA("Model") then
                    local bp = plotModel:FindFirstChild("BuildPlot")
                    if bp and #bp:GetChildren() > 0 then
                        return plotModel
                    end
                end
            end
        end

        local myPlot = findMyPlot()
        if not myPlot then
            return notify("Error", "Your plot was not found!", 4)
        end

        local centre = myPlot:FindFirstChild("Centre")
        local hrp    = getHRP()
        if centre and centre:IsA("BasePart") and hrp then
            hrp.CFrame = CFrame.new(centre.Position + Vector3.new(0, 3, 0))
            notify("Teleport", "Teleported to your Tycoon!", 3)
        else
            notify("Error", "Centre part not found in your plot!", 4)
        end
    end,
})

